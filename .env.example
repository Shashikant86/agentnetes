# ── AI Gateway (required for real execution) ──────────────────────────────────
# Get from: https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_BASE_URL=https://gateway.ai.vercel.app/v1/YOUR_TEAM/YOUR_GATEWAY

# ── Vercel Sandbox (required for real execution) ──────────────────────────────
# Set automatically on Vercel via OIDC. For local dev, use your Vercel token.
VERCEL_TOKEN=your_vercel_token_here

# ── Repo snapshot (strongly recommended) ─────────────────────────────────────
# Pre-warmed snapshot of the vercel/ai monorepo.
# Create it once by running: npx tsx scripts/create-snapshot.ts
# Without this, each agent clones the repo from git (adds ~30s per agent).
REPO_SNAPSHOT_ID=

# ── Optional: force simulation mode even if gateway is configured ─────────────
# Set to "true" to always use the simulated runtime (no API keys needed).
SIMULATION_MODE=false

# ── Optional: override which repo agents work on ──────────────────────────────
# Defaults to https://github.com/vercel/ai.git
REPO_GIT_URL=https://github.com/vercel/ai.git

# ── Web demo target (used by the web UI only) ─────────────────────────────────
DEMO_REPO_URL=https://github.com/vercel/ai
DEMO_REPO_SNAPSHOT_ID=   # optional, speeds up web demo
