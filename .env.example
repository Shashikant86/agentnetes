# ── Sandbox provider (auto-detected if not set) ───────────────────────────────
# Options: vercel | e2b | daytona | local
# Defaults to "local" if no provider credentials are found.
SANDBOX_PROVIDER=local

# ── Vercel Sandbox (set SANDBOX_PROVIDER=vercel) ──────────────────────────────
# Set automatically on Vercel via OIDC. For local dev, use your Vercel token.
VERCEL_TOKEN=your_vercel_token_here

# ── E2B Sandbox (set SANDBOX_PROVIDER=e2b) ────────────────────────────────────
# Get from: https://e2b.dev
E2B_API_KEY=your_e2b_api_key_here

# ── Daytona Sandbox (set SANDBOX_PROVIDER=daytona) ────────────────────────────
# Get from: https://daytona.io
DAYTONA_API_KEY=your_daytona_api_key_here

# ── AI Gateway (optional, routes LLM calls) ───────────────────────────────────
# If not set, falls back to GOOGLE_API_KEY directly.
AI_GATEWAY_BASE_URL=https://gateway.ai.vercel.app/v1/YOUR_TEAM/YOUR_GATEWAY
AI_GATEWAY_API_KEY=your_gateway_api_key_here

# ── Google Gemini direct (fallback when no gateway) ───────────────────────────
# Get free key from: https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# ── Simulation mode (set true to skip all real execution) ─────────────────────
SIMULATION_MODE=false

# ── Web demo target ───────────────────────────────────────────────────────────
DEMO_REPO_URL=https://github.com/vercel/ai
DEMO_REPO_SNAPSHOT_ID=
