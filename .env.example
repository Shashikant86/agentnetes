# ── Google Gemini API key (required for real execution) ───────────────────────
# Get a free key at: https://aistudio.google.com
# Can also be set in the web UI Settings modal — no .env.local needed.
GOOGLE_API_KEY=your_google_api_key_here

# ── Sandbox provider ──────────────────────────────────────────────────────────
# Options: docker | vercel | local
# docker  = isolated Docker containers (default, recommended for local dev)
# vercel  = Vercel Firecracker microVMs (auto-detected when deployed to Vercel)
# local   = runs shell commands directly on your machine, no isolation
SANDBOX_PROVIDER=docker

# ── Simulation mode ───────────────────────────────────────────────────────────
# Set to true to skip all real execution and use pre-scripted scenarios.
# The web UI has a Simulation / Real toggle -- this env var forces simulation server-side.
SIMULATION_MODE=false

# ── Web demo target repo ──────────────────────────────────────────────────────
# The git repo agents will clone into each sandbox.
# Use a small public repo for faster runs.
DEMO_REPO_URL=https://github.com/expressjs/express

# ── Optional: pre-warmed snapshot (Vercel sandbox only) ──────────────────────
# Run: agentnetes snapshot create
# Speeds up sandbox startup significantly.
DEMO_REPO_SNAPSHOT_ID=

# ── Optional: Vercel sandbox token ───────────────────────────────────────────
# Only needed if SANDBOX_PROVIDER=vercel and running outside Vercel (no OIDC).
VERCEL_TOKEN=

# ── Optional: static export mode (GitHub Pages / CDN) ────────────────────────
# Set to true when building for static hosting. Disables API routes.
# NEXT_PUBLIC_STATIC_MODE=false
